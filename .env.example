# NoneBot2 环境配置
# 复制此文件为 .env 并根据实际情况修改

ENVIRONMENT=prod
DRIVER=~fastapi
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# 命令起始字符
COMMAND_START=["/"]

# 超级用户 QQ 号列表（JSON 数组格式）
# 超级用户拥有最高权限，可处理所有群的进群请求
SUPERUSERS=["123456789"]

# 群白名单（JSON 数组格式），只在指定群处理进群请求与命令
# 为空或不配置则允许所有群
# ALLOWED_GROUP_IDS=["123456789","987654321"]

# 测试模式：设为 true 时，Bot 连接后会自动注入模拟进群请求并打印诊断日志
TEST_MODE=false

# 测试模式目标群号（纯数字），只在该群发送测试通知；不配置则使用默认群号
TEST_GROUP_ID=123456789

# 进群管理命令 trigger（只能是英文，默认 RCBOT）
# RCBOT_TRIGGER=RCBOT

# OneBot 访问令牌（可选，建议与 NapCat 配置保持一致以增强安全性）
# ONEBOT_ACCESS_TOKEN=your_token_here

# ========== ChatAI 群聊 AI 对话配置 ==========
# 启用群聊 AI 对话功能（被 @ 时回复）
CHAT_AI_ENABLED=false

# OpenAI 格式 API 密钥
# CHAT_AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# API 基础地址（使用第三方中转或本地模型时修改）
# CHAT_AI_BASE_URL=https://api.openai.com/v1

# 模型名称
# CHAT_AI_MODEL=gpt-4o-mini

# 最大记忆轮数（每轮 = 用户 + AI 各一条，默认 10）
# CHAT_AI_MAX_CONTEXT=10

# Prompt 文件说明：
# 将系统提示词写入 prompts/default.txt（默认）
# 如需按群定制，创建 prompts/<群号>.txt 即可
# 所有 .txt 文件已加入 .gitignore，不会上传
